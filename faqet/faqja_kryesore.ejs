<%- include('navbar.ejs', { perdoruesi: perdoruesi, isLoggedIn: isLoggedIn }) %>

<div class="products-container">
    <div class="products-header">
        <h1>Zbuloni Produktet Tona</h1>
        <p>Gjeni ofertat më të mira për produkte me cilësi</p>
    </div>

    <div class="products-grid">
        <% produktet.forEach(function(produkti) { %>
            <div class="product-card">
                <div class="product-image" style="background-image: url('<%= produkti.foto %>');"></div>
                
                <div class="product-info">
                    <h3 class="product-title"><%= produkti.emri %></h3>
                    <div class="product-price">
                        <span class="price-amount">€<%= produkti.cmimi %></span>
                        <% if(produkti.stoku > 0) { %>
                            <span class="stock-badge in-stock">Në Stok</span>
                        <% } else { %>
                            <span class="stock-badge out-of-stock">Jo në Stok</span>
                        <% } %>
                    </div>
                    <a href="/produkti/<%= produkti.id %>" class="view-details-btn">
                        <span>Shiko Detajet</span>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                    </a>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<style>
    .products-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 3rem 2rem;
    }

    .products-header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .products-header h1 {
        font-size: 2.5rem;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 0.5rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .products-header p {
        font-size: 1.1rem;
        color: #6b7280;
    }

    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 2rem;
    }

    .product-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        transition: all 0.3s;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    }

    .product-image {
        width: 100%;
        height: 250px;
        background-position: center;
        background-repeat: no-repeat;
        background-size: cover;
        position: relative;
    }

    .product-info {
        padding: 1.5rem;
    }

    .product-title {
        font-size: 1.2rem;
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 1rem;
        min-height: 2.4rem;
    }

    .product-price {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }

    .price-amount {
        font-size: 1.75rem;
        font-weight: 700;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .stock-badge {
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.35rem 0.75rem;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .stock-badge.in-stock {
        background: #d1fae5;
        color: #065f46;
    }

    .stock-badge.out-of-stock {
        background: #fee2e2;
        color: #991b1b;
    }

    .view-details-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        width: 100%;
        padding: 0.875rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        text-decoration: none;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s;
    }

    .view-details-btn:hover {
        transform: scale(1.02);
        box-shadow: 0 10px 15px -3px rgba(102, 126, 234, 0.4);
    }

    .view-details-btn svg {
        stroke-width: 2.5;
        transition: transform 0.3s;
    }

    .view-details-btn:hover svg {
        transform: translateX(4px);
    }

    @media (max-width: 1024px) {
        .products-grid {
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 1.5rem;
        }
    }

    @media (max-width: 768px) {
        .products-container {
            padding: 2rem 1rem;
        }

        .products-header {
            margin-bottom: 2rem;
        }

        .products-header h1 {
            font-size: 2rem;
        }

        .products-header p {
            font-size: 1rem;
        }

        .products-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
        }

        .product-card {
            border-radius: 12px;
        }

        .product-image {
            height: 160px;
        }

        .product-info {
            padding: 1rem;
        }

        .product-title {
            font-size: 0.95rem;
            min-height: 2.4rem;
            margin-bottom: 0.75rem;
        }

        .price-amount {
            font-size: 1.4rem;
        }

        .stock-badge {
            font-size: 0.65rem;
            padding: 0.25rem 0.6rem;
        }

        .view-details-btn {
            padding: 0.75rem;
            font-size: 0.85rem;
            gap: 0.4rem;
        }

        .view-details-btn svg {
            width: 14px;
            height: 14px;
        }
    }

    @media (max-width: 480px) {
        .products-container {
            padding: 1.5rem 0.75rem;
        }

        .products-header h1 {
            font-size: 1.75rem;
        }

        .products-grid {
            grid-template-columns: 1fr;
            gap: 1.25rem;
        }

        .product-card {
            display: flex;
            gap: 1rem;
        }

        .product-image {
            width: 120px;
            height: 120px;
            flex-shrink: 0;
        }

        .product-info {
            flex: 1;
            display: flex;
            flex-direction: column;
            padding: 0.75rem;
        }

        .product-title {
            font-size: 1rem;
            min-height: auto;
            margin-bottom: 0.5rem;
        }

        .product-price {
            margin-bottom: 0.75rem;
        }

        .price-amount {
            font-size: 1.5rem;
        }

        .view-details-btn {
            padding: 0.65rem;
            font-size: 0.9rem;
            margin-top: auto;
        }
    }
</style>

<%- include('footer.ejs') %>
