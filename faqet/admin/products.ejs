<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Products - Admin Panel</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="admin-layout">
    <%- include('../admin/sidebar') %>

    <main class="admin-main">
        <div class="admin-header">
            <h1>Products Management</h1>
            <button onclick="openAddModal()" class="btn-primary">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <line x1="12" x2="12" y1="5" y2="19"></line>
                    <line x1="5" x2="19" y1="12" y2="12"></line>
                </svg>
                Add New Product
            </button>
        </div>

        <div class="products-table-container">
            <table class="products-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% products.forEach(function(product) { %>
                        <tr>
                            <td>#<%= product.id %></td>
                            <td>
                                <div class="product-img" style="background-image: url('<%= product.foto %>');"></div>
                            </td>
                            <td><strong><%= product.emri %></strong></td>
                            <td>€<%= product.cmimi %></td>
                            <td>
                                <% if (product.stoku > 10) { %>
                                    <span class="badge success"><%= product.stoku %> in stock</span>
                                <% } else if (product.stoku > 0) { %>
                                    <span class="badge warning"><%= product.stoku %> in stock</span>
                                <% } else { %>
                                    <span class="badge danger">Out of stock</span>
                                <% } %>
                            </td>
                            <td>
                                <div class="action-btns">
                                    <button onclick='editProduct(<%= JSON.stringify(product) %>)' class="btn-edit">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                        </svg>
                                    </button>
                                    <button onclick="deleteProduct(<%= product.id %>, '<%= product.emri %>')" class="btn-delete">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                            <polyline points="3 6 5 6 21 6"></polyline>
                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </main>
</div>

<!-- Add/Edit Product Modal -->
<div id="productModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 id="modalTitle">Add New Product</h2>
            <button onclick="closeModal()" class="close-btn">&times;</button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="productId">
            
            <div class="form-group">
                <label>Product Name</label>
                <input type="text" id="productName" placeholder="e.g., Gaming Laptop">
            </div>

            <div class="form-group">
                <label>Description</label>
                <textarea id="productDesc" rows="3" placeholder="Product description..."></textarea>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Price (€)</label>
                    <input type="number" id="productPrice" step="0.01" placeholder="99.99">
                </div>

                <div class="form-group">
                    <label>Stock</label>
                    <input type="number" id="productStock" placeholder="50">
                </div>
            </div>

            <div class="form-group">
                <label>Image URL</label>
                <input type="text" id="productImage" placeholder="https://example.com/image.jpg">
                <small>Recommended: Use Unsplash images (https://unsplash.com)</small>
            </div>

            <div id="imagePreview" class="image-preview"></div>
        </div>
        <div class="modal-footer">
            <button onclick="closeModal()" class="btn-secondary">Cancel</button>
            <button onclick="saveProduct()" class="btn-primary" id="saveBtn">Save Product</button>
        </div>
    </div>
</div>

<script>
let isEditMode = false;

function openAddModal() {
    isEditMode = false;
    document.getElementById('modalTitle').textContent = 'Add New Product';
    document.getElementById('saveBtn').textContent = 'Add Product';
    document.getElementById('productId').value = '';
    document.getElementById('productName').value = '';
    document.getElementById('productDesc').value = '';
    document.getElementById('productPrice').value = '';
    document.getElementById('productStock').value = '';
    document.getElementById('productImage').value = '';
    document.getElementById('imagePreview').style.display = 'none';
    document.getElementById('productModal').style.display = 'flex';
}

function editProduct(product) {
    isEditMode = true;
    document.getElementById('modalTitle').textContent = 'Edit Product';
    document.getElementById('saveBtn').textContent = 'Update Product';
    document.getElementById('productId').value = product.id;
    document.getElementById('productName').value = product.emri;
    document.getElementById('productDesc').value = product.pershkrimi;
    document.getElementById('productPrice').value = product.cmimi;
    document.getElementById('productStock').value = product.stoku;
    document.getElementById('productImage').value = product.foto;
    
    let preview = document.getElementById('imagePreview');
    preview.style.backgroundImage = `url('${product.foto}')`;
    preview.style.display = 'block';
    
    document.getElementById('productModal').style.display = 'flex';
}

function closeModal() {
    document.getElementById('productModal').style.display = 'none';
}

function saveProduct() {
    let id = document.getElementById('productId').value;
    let emri = document.getElementById('productName').value;
    let pershkrimi = document.getElementById('productDesc').value;
    let cmimi = document.getElementById('productPrice').value;
    let stoku = document.getElementById('productStock').value;
    let foto = document.getElementById('productImage').value;

    if (!emri || !pershkrimi || !cmimi || !stoku || !foto) {
        return alert('Please fill all fields');
    }

    let url = isEditMode ? '/admin/products/update' : '/admin/products/add';
    let data = { emri, pershkrimi, cmimi, stoku, foto };
    
    if (isEditMode) {
        data.id = id;
    }

    fetch(url, {
        method: 'POST',
        body: JSON.stringify(data)
    })
    .then(res => res.json())
    .then(data => {
        if (data.error) {
            alert(data.mesazhi);
        } else {
            alert(data.mesazhi);
            window.location.reload();
        }
    });
}

function deleteProduct(id, name) {
    if (!confirm(`Are you sure you want to delete "${name}"?`)) {
        return;
    }

    fetch('/admin/products/delete', {
        method: 'POST',
        body: JSON.stringify({ id })
    })
    .then(res => res.json())
    .then(data => {
        if (data.error) {
            alert(data.mesazhi);
        } else {
            alert(data.mesazhi);
            window.location.reload();
        }
    });
}

// Image preview
document.getElementById('productImage').addEventListener('input', function() {
    let url = this.value;
    let preview = document.getElementById('imagePreview');
    if (url) {
        preview.style.backgroundImage = `url('${url}')`;
        preview.style.display = 'block';
    } else {
        preview.style.display = 'none';
    }
});

// Close modal on outside click
window.onclick = function(event) {
    let modal = document.getElementById('productModal');
    if (event.target == modal) {
        closeModal();
    }
}
</script>

<%- include('../admin/styles') %>

</body>
</html>
