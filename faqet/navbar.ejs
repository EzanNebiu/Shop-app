<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>E-commerce</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<!-- Mobile Drawer Overlay -->
<div class="drawer-overlay" id="drawerOverlay"></div>

<!-- Mobile Drawer -->
<div class="mobile-drawer" id="mobileDrawer">
    <div class="drawer-header">
        <div class="drawer-brand">
            <svg width="32" height="32" viewBox="0 0 40 40" fill="none">
                <rect width="40" height="40" rx="8" fill="url(#gradient-drawer)"/>
                <path d="M12 20L18 26L28 14" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                <defs>
                    <linearGradient id="gradient-drawer" x1="0" y1="0" x2="40" y2="40">
                        <stop offset="0%" style="stop-color:#667eea"/>
                        <stop offset="100%" style="stop-color:#764ba2"/>
                    </linearGradient>
                </defs>
            </svg>
            <span>E-commerce</span>
        </div>
        <button class="drawer-close" id="drawerClose">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
    </div>

    <div class="drawer-content">
        <% if (isLoggedIn) { %>
            <div class="drawer-user">
                <div class="drawer-avatar">
                    <%= perdoruesi.emri.charAt(0).toUpperCase() %>
                </div>
                <div class="drawer-user-info">
                    <h3><%= perdoruesi.emri %></h3>
                    <p><%= perdoruesi.email %></p>
                </div>
            </div>

            <div class="drawer-divider"></div>

            <nav class="drawer-nav">
                <a href="/" class="drawer-link">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                    </svg>
                    Kryefaqja
                </a>
                <a href="/orders" class="drawer-link">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="9" cy="21" r="1"></circle>
                        <circle cx="20" cy="21" r="1"></circle>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                    </svg>
                    Porositë e Mia
                </a>
                <a href="/profili" class="drawer-link">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                    Profili
                </a>
                <a href="/logout" class="drawer-link logout">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                        <polyline points="16 17 21 12 16 7"></polyline>
                        <line x1="21" y1="12" x2="9" y2="12"></line>
                    </svg>
                    Dilni
                </a>
            </nav>
        <% } else { %>
            <nav class="drawer-nav">
                <a href="/" class="drawer-link">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                    </svg>
                    Kryefaqja
                </a>
                <a href="/login" class="drawer-link">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
                        <polyline points="10 17 15 12 10 7"></polyline>
                        <line x1="15" y1="12" x2="3" y2="12"></line>
                    </svg>
                    Kyçu
                </a>
                <a href="/register" class="drawer-link primary">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="8.5" cy="7" r="4"></circle>
                        <line x1="20" y1="8" x2="20" y2="14"></line>
                        <line x1="23" y1="11" x2="17" y2="11"></line>
                    </svg>
                    Regjistrohu
                </a>
            </nav>
        <% } %>
    </div>
</div>

<!-- Full-Screen Search Overlay -->
<div class="search-overlay" id="searchOverlay">
    <div class="search-overlay-header">
        <button class="search-back-btn" id="searchBackBtn">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
        </button>
        <div class="search-overlay-input-wrapper">
            <svg class="search-overlay-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
            </svg>
            <input 
                type="text" 
                id="searchOverlayInput" 
                placeholder="Kërko produkte..." 
                autocomplete="off"
                autofocus
            >
            <button class="search-clear-btn" id="searchClearBtn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
    </div>
    
    <div class="search-overlay-content" id="searchOverlayContent">
        <div class="search-overlay-results" id="searchOverlayResults"></div>
    </div>
</div>

<nav class="modern-navbar">
    <div class="nav-container">
        <button class="mobile-menu-btn" id="mobileMenuBtn">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
        </button>

        <div class="nav-brand">
            <a href="/">
                <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                    <rect width="40" height="40" rx="8" fill="url(#gradient)"/>
                    <path d="M12 20L18 26L28 14" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                    <defs>
                        <linearGradient id="gradient" x1="0" y1="0" x2="40" y2="40">
                            <stop offset="0%" style="stop-color:#667eea"/>
                            <stop offset="100%" style="stop-color:#764ba2"/>
                        </linearGradient>
                    </defs>
                </svg>
                <span class="brand-name">E-commerce</span>
            </a>
        </div>

        <!-- Desktop Search -->
        <div class="nav-search desktop-search">
            <form id="searchForma" action="">
                <div class="search-wrapper">
                    <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <circle cx="11" cy="11" r="8"></circle>
                        <path d="m21 21-4.35-4.35"></path>
                    </svg>
                    <input type="text" id="kerkimi" name="kerkimi" placeholder="Kërko produkte..." autocomplete="off">
                    <div id="searchResults" class="search-results"></div>
                </div>
            </form>
        </div>

        <!-- Mobile Search Button -->
        <button class="mobile-search-btn" id="mobileSearchBtn">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
            </svg>
        </button>

        <div class="nav-actions">
            <%  if(!isLoggedIn) { %>
                <a href="/login" class="nav-link">Kyçu</a>
                <a href="/register" class="btn-primary">Regjistrohu</a>
            <% } else { %>
                <a href="/orders" class="nav-link">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle; margin-right: 0.25rem;">
                        <circle cx="9" cy="21" r="1"></circle>
                        <circle cx="20" cy="21" r="1"></circle>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                    </svg>
                    Porositë e Mia
                </a>
                <a href="/profili" class="user-profile">
                    <div class="avatar"><%= perdoruesi.emri.charAt(0).toUpperCase() %></div>
                    <span><%= perdoruesi.emri %></span>
                </a>
                <a href="/logout" class="btn-outline">Dilni</a>
            <% } %>
        </div>
    </div>
</nav>

<script>
// Drawer functionality
function toggleMobileMenu() {
    const drawer = document.getElementById('mobileDrawer');
    const overlay = document.getElementById('drawerOverlay');
    drawer.classList.toggle('active');
    overlay.classList.toggle('active');
    document.body.style.overflow = drawer.classList.contains('active') ? 'hidden' : '';
}

// Search overlay functionality
function openSearchOverlay() {
    const searchOverlay = document.getElementById('searchOverlay');
    searchOverlay.classList.add('active');
    document.body.style.overflow = 'hidden';
    
    // Focus input after animation
    setTimeout(() => {
        document.getElementById('searchOverlayInput').focus();
    }, 300);
}

function closeSearchOverlay() {
    const searchOverlay = document.getElementById('searchOverlay');
    searchOverlay.classList.remove('active');
    document.body.style.overflow = '';
    
    // Clear search
    document.getElementById('searchOverlayInput').value = '';
    document.getElementById('searchOverlayResults').innerHTML = '';
}

document.addEventListener('DOMContentLoaded', function() {
    // Drawer events
    const mobileMenuBtn = document.getElementById('mobileMenuBtn');
    const drawerClose = document.getElementById('drawerClose');
    const drawerOverlay = document.getElementById('drawerOverlay');
    
    if (mobileMenuBtn) {
        mobileMenuBtn.addEventListener('click', toggleMobileMenu);
    }
    
    if (drawerClose) {
        drawerClose.addEventListener('click', toggleMobileMenu);
    }
    
    if (drawerOverlay) {
        drawerOverlay.addEventListener('click', toggleMobileMenu);
    }
    
    // Search overlay events
    const mobileSearchBtn = document.getElementById('mobileSearchBtn');
    const searchBackBtn = document.getElementById('searchBackBtn');
    const searchClearBtn = document.getElementById('searchClearBtn');
    const searchOverlayInput = document.getElementById('searchOverlayInput');
    
    if (mobileSearchBtn) {
        mobileSearchBtn.addEventListener('click', openSearchOverlay);
    }
    
    if (searchBackBtn) {
        searchBackBtn.addEventListener('click', closeSearchOverlay);
    }
    
    if (searchClearBtn) {
        searchClearBtn.addEventListener('click', function() {
            searchOverlayInput.value = '';
            searchOverlayInput.focus();
            document.getElementById('searchOverlayResults').innerHTML = '';
        });
    }
});

// Live Search Functionality
const searchInput = document.getElementById('kerkimi');
const searchResults = document.getElementById('searchResults');
const searchOverlayInput = document.getElementById('searchOverlayInput');
const searchOverlayResults = document.getElementById('searchOverlayResults');
let searchTimeout;

function performSearch(query, resultsContainer, isOverlay = false) {
    clearTimeout(searchTimeout);
    
    if (query.length === 0) {
        resultsContainer.innerHTML = '';
        if (!isOverlay) resultsContainer.style.display = 'none';
        return;
    }
    
    if (query.length < 2) {
        return;
    }
    
    searchTimeout = setTimeout(() => {
        fetch(`/?kerkimi=${encodeURIComponent(query)}`)
            .then(response => response.text())
            .then(html => {
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                const products = doc.querySelectorAll('.product-card');
                
                if (products.length === 0) {
                    resultsContainer.innerHTML = `
                        <div class="search-no-results">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"></circle>
                                <line x1="15" y1="9" x2="9" y2="15"></line>
                                <line x1="9" y1="9" x2="15" y2="15"></line>
                            </svg>
                            <p>Nuk u gjetën produkte</p>
                            <span>Provoni një term tjetër kërkimi</span>
                        </div>
                    `;
                } else {
                    let resultsHTML = isOverlay ? '<div class="search-overlay-header-text">Rezultatet e Kërkimit</div>' : '<div class="search-header">Rezultatet e Kërkimit</div>';
                    
                    const maxResults = isOverlay ? products.length : 5;
                    products.forEach((product, index) => {
                        if (index < maxResults) {
                            const title = product.querySelector('.product-title')?.textContent || '';
                            const price = product.querySelector('.price-amount')?.textContent || '';
                            const link = product.querySelector('.view-details-btn')?.href || '';
                            const image = product.querySelector('.product-image')?.style.backgroundImage || '';
                            
                            const itemClass = isOverlay ? 'search-overlay-result-item' : 'search-result-item';
                            resultsHTML += `
                                <a href="${link}" class="${itemClass}">
                                    <div class="search-result-image" style="${image}"></div>
                                    <div class="search-result-info">
                                        <div class="search-result-title">${title}</div>
                                        <div class="search-result-price">${price}</div>
                                    </div>
                                </a>
                            `;
                        }
                    });
                    
                    if (!isOverlay && products.length > 5) {
                        resultsHTML += `
                            <div class="search-result-footer">
                                <a href="/?kerkimi=${encodeURIComponent(query)}">
                                    Shiko të gjitha ${products.length} rezultatet →
                                </a>
                            </div>
                        `;
                    }
                    
                    resultsContainer.innerHTML = resultsHTML;
                }
                
                if (!isOverlay) resultsContainer.style.display = 'block';
            })
            .catch(error => {
                console.error('Search error:', error);
            });
    }, 300);
}

// Desktop search
if (searchInput) {
    searchInput.addEventListener('input', function(e) {
        performSearch(e.target.value.trim(), searchResults, false);
    });

    searchInput.addEventListener('focus', function() {
        if (this.value.trim().length >= 2 && searchResults.innerHTML) {
            searchResults.style.display = 'block';
        }
    });

    document.addEventListener('click', function(event) {
        if (!searchInput.contains(event.target) && !searchResults.contains(event.target)) {
            searchResults.style.display = 'none';
        }
    });
}

// Mobile overlay search
if (searchOverlayInput) {
    searchOverlayInput.addEventListener('input', function(e) {
        performSearch(e.target.value.trim(), searchOverlayResults, true);
    });
}
</script>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        min-height: 100vh;
    }

    /* Drawer Overlay */
    .drawer-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(4px);
        z-index: 9998;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s ease, visibility 0.3s ease;
    }

    .drawer-overlay.active {
        opacity: 1;
        visibility: visible;
    }

    /* Mobile Drawer */
    .mobile-drawer {
        position: fixed;
        top: 0;
        left: -100%;
        width: 320px;
        max-width: 85vw;
        height: 100%;
        background: white;
        box-shadow: 2px 0 20px rgba(0, 0, 0, 0.1);
        z-index: 9999;
        transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        overflow-y: auto;
    }

    .mobile-drawer.active {
        left: 0;
    }

    .drawer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem;
        border-bottom: 1px solid #e5e7eb;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .drawer-brand {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .drawer-brand span {
        font-size: 1.25rem;
        font-weight: 700;
    }

    .drawer-close {
        background: rgba(255, 255, 255, 0.2);
        border: none;
        color: white;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .drawer-close:hover {
        background: rgba(255, 255, 255, 0.3);
        transform: rotate(90deg);
    }

    .drawer-content {
        padding: 1rem 0;
    }

    .drawer-user {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.5rem 1.5rem;
        background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
        margin-bottom: 1rem;
    }

    .drawer-avatar {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
        font-weight: 600;
        flex-shrink: 0;
    }

    .drawer-user-info {
        flex: 1;
        overflow: hidden;
    }

    .drawer-user-info h3 {
        font-size: 1.125rem;
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 0.25rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .drawer-user-info p {
        font-size: 0.875rem;
        color: #6b7280;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .drawer-divider {
        height: 1px;
        background: #e5e7eb;
        margin: 0.5rem 1.5rem;
    }

    .drawer-nav {
        padding: 0.5rem 0;
    }

    .drawer-link {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.5rem;
        color: #4b5563;
        text-decoration: none;
        font-size: 1rem;
        font-weight: 500;
        transition: all 0.2s ease;
        position: relative;
    }

    .drawer-link::before {
        content: '';
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 4px;
        height: 0;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 0 4px 4px 0;
        transition: height 0.2s ease;
    }

    .drawer-link:hover {
        background: linear-gradient(90deg, rgba(102, 126, 234, 0.05) 0%, transparent 100%);
        color: #667eea;
    }

    .drawer-link:hover::before {
        height: 60%;
    }

    .drawer-link svg {
        flex-shrink: 0;
    }

    .drawer-link.primary {
        margin: 1rem 1.5rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 12px;
        padding: 1rem 1.5rem;
        font-weight: 600;
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
    }

    .drawer-link.primary::before {
        display: none;
    }

    .drawer-link.primary:hover {
        background: linear-gradient(135deg, #5a6fd8 0%, #6a4190 100%);
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(102, 126, 234, 0.4);
    }

    .drawer-link.logout {
        color: #dc2626;
    }

    .drawer-link.logout:hover {
        background: rgba(220, 38, 38, 0.05);
        color: #b91c1c;
    }

    .drawer-link.logout::before {
        background: #dc2626;
    }

    /* Full-Screen Search Overlay */
    .search-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: white;
        z-index: 10000;
        transform: translateY(100%);
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .search-overlay.active {
        transform: translateY(0);
    }

    .search-overlay-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        border-bottom: 2px solid #e5e7eb;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .search-back-btn {
        background: rgba(255, 255, 255, 0.2);
        border: none;
        color: white;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        flex-shrink: 0;
    }

    .search-back-btn:hover {
        background: rgba(255, 255, 255, 0.3);
        transform: scale(1.05);
    }

    .search-overlay-input-wrapper {
        flex: 1;
        position: relative;
        display: flex;
        align-items: center;
        background: white;
        border-radius: 50px;
        padding: 0 1rem;
        min-width: 0;
        max-width: 100%;
    }

    .search-overlay-icon {
        color: #667eea;
        flex-shrink: 0;
        margin-right: 0.75rem;
    }

    #searchOverlayInput {
        flex: 1;
        min-width: 0;
        max-width: 100%;
        border: none;
        outline: none;
        padding: 1rem 0;
        font-size: 1.125rem;
        color: #1f2937;
        background: transparent;
    }

    #searchOverlayInput::placeholder {
        color: #9ca3af;
    }

    .search-clear-btn {
        background: rgba(102, 126, 234, 0.1);
        border: none;
        color: #667eea;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        flex-shrink: 0;
        opacity: 0;
        pointer-events: none;
    }

    #searchOverlayInput:not(:placeholder-shown) ~ .search-clear-btn {
        opacity: 1;
        pointer-events: all;
    }

    .search-clear-btn:hover {
        background: rgba(102, 126, 234, 0.2);
    }

    .search-overlay-content {
        height: calc(100% - 80px);
        overflow-y: auto;
