<%- include('navbar.ejs', {
    perdoruesi: perdoruesi,
    isLoggedIn: isLoggedIn
}) %>

<div class="product-detail-container">
    <% 
        let klasa_stok = produkti.stoku == 0 ? 'out-of-stock' : ''
    %>

    <div class="product-detail-card">
        <div class="product-image-section">
            <div class="product-large-image <%= klasa_stok %>" style="background-image: url('<%= produkti.foto %>');"></div>
            <% if (produkti.stoku == 0) { %>
                <div class="out-of-stock-badge">Jo në Stok</div>
            <% } %>
        </div>

        <input type="hidden" id="produkti_id" name="produkti_id" value="<%= produkti.id %>">

        <div class="product-details-section">
            <h1 class="product-name"><%= produkti.emri %></h1>
            <p class="product-description"><%= produkti.pershkrimi %></p>
            
            <div class="price-section">
                <div class="price-label">Çmimi</div>
                <div class="price-value">€<%= produkti.cmimi %></div>
            </div>

            <input type="hidden" id="cmimi_total_hidden" value="<%= produkti.cmimi %>">

            <div class="total-price-section">
                <span>Çmimi Total:</span>
                <span class="total-amount">€<span id="cmimi_total"><%= produkti.cmimi %></span></span>
            </div>

            <div class="quantity-section">
                <label>Sasia</label>
                <div class="quantity-controls">
                    <button id="minus_button" class="qty-btn">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M5 12h14"/>
                        </svg>
                    </button>
                    <input type="number" id="sasia" name="sasia" value="1" min="1" max="<%= produkti.stoku %>">
                    <button id="plus_button" class="qty-btn">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M12 5v14M5 12h14"/>
                        </svg>
                    </button>
                </div>
            </div>

            <div class="stock-info">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <path d="M21 10H3M21 6H3M21 14H3M21 18H3"></path>
                </svg>
                <span><strong><%= produkti.stoku %></strong> artikuj në dispozicion</span>
            </div>

            <button class="buy-now-btn <%= produkti.stoku == 0 ? 'disabled' : '' %>" <%= produkti.stoku == 0 ? 'disabled' : '' %>>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <circle cx="9" cy="21" r="1"></circle>
                    <circle cx="20" cy="21" r="1"></circle>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                </svg>
                <span><%= produkti.stoku == 0 ? 'Jo në Stok' : 'Blej Tani' %></span>
            </button>
        </div>
    </div>
</div>

<script>
    let minus_button = document.querySelector("#minus_button")
    let plus_button = document.querySelector("#plus_button")
    let sasia_input = document.querySelector("#sasia")
    let cmimi_total = document.querySelector("#cmimi_total")
    let cmimi_total_hidden = document.querySelector("#cmimi_total_hidden")
    let blej_button = document.querySelector('.buy-now-btn')

    sasia_input.addEventListener('input', function() {
        let cmimi = cmimi_total_hidden.value
        let sasia = sasia_input.value
        cmimi_total.textContent = (cmimi * sasia).toFixed(2)
    })

    minus_button.addEventListener('click', function() {
        let cmimi = cmimi_total_hidden.value

        if (sasia_input.value > 1) {
            sasia_input.value--
            let cmimi_i_ri = cmimi * sasia_input.value
            cmimi_total.textContent = cmimi_i_ri.toFixed(2)
        }
    })

    plus_button.addEventListener('click', function() {
        let cmimi = cmimi_total_hidden.value
        let max = parseInt(sasia_input.max)
        
        if (parseInt(sasia_input.value) < max) {
            sasia_input.value++
            let cmimi_i_ri = cmimi * sasia_input.value
            cmimi_total.textContent = cmimi_i_ri.toFixed(2)
        }
    })

    blej_button.addEventListener('click', function() {
        if (blej_button.classList.contains('disabled')) return;

        let produkti_id = document.querySelector('#produkti_id').value
        let sasia = document.querySelector("#sasia").value
        let cmimi = document.querySelector("#cmimi_total_hidden").value

        let blerja = {
            produkti_id: produkti_id,
            sasia: sasia,
            cmimi: cmimi
        }

        fetch("/blej_produktin", {
            method: 'POST',
            body: JSON.stringify(blerja)
        }).then(function(response) {
            return response.json()
        }).then(function(data) {
            if(data.error) {
                if(data.redirect) {
                    alert('Ju lutemi kyçuni për të blerë')
                    window.location.href = '/login'
                } else {
                    alert(data.mesazhi)
                }                
            } else {
                alert('Blerja u krye me sukses!')
                window.location.href = '/fatura/' + data.blerja_id
            }
        })
    })
</script>

<style>
    .product-detail-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 3rem 2rem;
    }

    .product-detail-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        padding: 3rem;
    }

    .product-image-section {
        position: relative;
    }

    .product-large-image {
        width: 100%;
        height: 500px;
        background-position: center;
        background-repeat: no-repeat;
        background-size: contain;
        border-radius: 16px;
        background-color: #f9fafb;
    }

    .product-large-image.out-of-stock {
        opacity: 0.5;
        filter: grayscale(50%);
    }

    .out-of-stock-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: #dc2626;
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .product-details-section {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .product-name {
        font-size: 2rem;
        font-weight: 700;
        color: #1f2937;
    }

    .product-description {
        color: #6b7280;
        font-size: 1.1rem;
        line-height: 1.6;
    }

    .price-section {
        padding: 1.5rem;
        background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
        border-radius: 12px;
    }

    .price-label {
        color: #6b7280;
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }

    .price-value {
        font-size: 2.5rem;
        font-weight: 700;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .total-price-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem;
        background: #f9fafb;
        border-radius: 10px;
        font-size: 1.1rem;
    }

    .total-amount {
        font-size: 1.5rem;
        font-weight: 700;
        color: #1f2937;
    }

    .quantity-section label {
        display: block;
        font-weight: 600;
        color: #374151;
        margin-bottom: 0.5rem;
    }

    .quantity-controls {
        display: flex;
        gap: 0;
    }

    .qty-btn {
        padding: 0.75rem 1rem;
        border: 2px solid #e5e7eb;
        background: white;
        cursor: pointer;
        transition: all 0.2s;
    }

    .qty-btn:hover {
        background: #f3f4f6;
        border-color: #667eea;
    }

    .qty-btn svg {
        stroke-width: 2.5;
        color: #374151;
    }

    #minus_button {
        border-radius: 10px 0 0 10px;
    }

    #plus_button {
        border-radius: 0 10px 10px 0;
        border-left: none;
    }

    #sasia {
        width: 80px;
        text-align: center;
        border: 2px solid #e5e7eb;
        border-left: none;
        border-right: none;
        font-size: 1.1rem;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
    }

    #sasia:focus {
        outline: none;
    }

    .stock-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: #6b7280;
        padding: 1rem;
        background: #f9fafb;
        border-radius: 10px;
    }

    .stock-info svg {
        stroke-width: 2;
    }

    .buy-now-btn {
        width: 100%;
        padding: 1.25rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        margin-top: 1rem;
    }

    .buy-now-btn:hover:not(.disabled) {
        transform: translateY(-2px);
        box-shadow: 0 15px 20px -5px rgba(102, 126, 234, 0.4);
    }

    .buy-now-btn.disabled {
        background: #9ca3af;
        cursor: not-allowed;
    }

    .buy-now-btn svg {
        stroke-width: 2;
    }

    @media (max-width: 768px) {
        .product-detail-container {
            padding: 2rem 1rem;
        }

        .product-detail-card {
            grid-template-columns: 1fr;
            padding: 1.5rem;
            gap: 2rem;
        }

        .product-large-image {
            height: 300px;
        }

        .product-name {
            font-size: 1.5rem;
        }

        .product-description {
            font-size: 1rem;
        }

        .price-value {
            font-size: 2rem;
        }

        .form-row {
            grid-template-columns: 1fr;
        }

        .buy-now-btn {
            padding: 1rem;
            font-size: 1rem;
        }
    }

    @media (max-width: 480px) {
        .product-detail-card {
            padding: 1rem;
        }

        .product-large-image {
            height: 250px;
        }

        .product-name {
            font-size: 1.25rem;
        }

        .price-value {
            font-size: 1.75rem;
        }

        .total-price-section {
            font-size: 0.95rem;
        }

        .total-amount {
            font-size: 1.25rem;
        }
    }
</style>

<%- include('footer.ejs') %>