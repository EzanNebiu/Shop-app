<%- include('navbar.ejs', {perdoruesi: perdoruesi, isLoggedIn: isLoggedIn}) %>

<div class="orders-container">
    <div class="orders-header">
        <h1>
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="9" cy="21" r="1"></circle>
                <circle cx="20" cy="21" r="1"></circle>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
            </svg>
            Porositë e Mia
        </h1>
        <p>Shiko dhe gjurmo të gjitha porositë tuaja</p>
    </div>

    <% if (orders.length === 0) { %>
        <div class="no-orders">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="9" cy="21" r="1"></circle>
                <circle cx="20" cy="21" r="1"></circle>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
            </svg>
            <h2>Ende Nuk Keni Porosite</h2>
            <p>Filloni blerjet për të parë porositë tuaja këtu!</p>
            <a href="/" class="shop-now-btn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 16 16 12 12 8"></polyline>
                    <line x1="8" y1="12" x2="16" y2="12"></line>
                </svg>
                Filloni Blerjet
            </a>
        </div>
    <% } else { %>
        <div class="orders-grid">
            <% orders.forEach(function(order) { %>
                <div class="order-card">
                    <div class="order-card-header">
                        <div class="order-id">
                            <span class="order-label">Porosia #</span>
                            <span class="order-number"><%= order.id %></span>
                        </div>
                        <div class="order-date">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                <line x1="3" y1="10" x2="21" y2="10"></line>
                            </svg>
                            <%= new Date(order.data_e_blerjes).toLocaleDateString('en-US', { 
                                year: 'numeric', 
                                month: 'short', 
                                day: 'numeric',
                                hour: '2-digit',
                                minute: '2-digit'
                            }) %>
                        </div>
                    </div>

                    <div class="order-content">
                        <div class="order-product">
                            <div class="order-product-image" style="background-image: url('<%= order.produkti_foto %>')"></div>
                            <div class="order-product-info">
                                <h3><%= order.produkti_emri %></h3>
                                <div class="order-details">
                                    <span class="quantity-badge">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <line x1="12" y1="1" x2="12" y2="23"></line>
                                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                                        </svg>
                                        Sasia: <%= order.sasia %>
                                    </span>
                                    <span class="price-badge">€<%= order.produkti_cmimi.toFixed(2) %> each</span>
                                </div>
                            </div>
                        </div>

                        <div class="order-footer">
                            <div class="order-total">
                                <span>Totali</span>
                                <span class="total-amount">€<%= order.cmimi_total.toFixed(2) %></span>
                            </div>
                            <div class="order-actions">
                                <a href="/fatura/<%= order.id %>" class="btn-invoice">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                        <polyline points="14 2 14 8 20 8"></polyline>
                                        <line x1="16" y1="13" x2="8" y2="13"></line>
                                        <line x1="16" y1="17" x2="8" y2="17"></line>
                                        <polyline points="10 9 9 9 8 9"></polyline>
                                    </svg>
                                    Shiko Faturën
                                </a>
                                <a href="/produkti/<%= order.produkti_id %>" class="btn-view">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                        <circle cx="12" cy="12" r="3"></circle>
                                    </svg>
                                    Shiko Produktin
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>

<%- include('footer.ejs') %>

<style>
    .orders-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1rem;
        min-height: calc(100vh - 200px);
    }

    .orders-header {
        text-align: center;
        margin-bottom: 3rem;
        padding: 2rem 0;
    }

    .orders-header h1 {
        font-size: 2.5rem;
        font-weight: 700;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        margin-bottom: 0.5rem;
    }

    .orders-header h1 svg {
        stroke: #667eea;
    }

    .orders-header p {
        color: #6b7280;
        font-size: 1.125rem;
    }

    .no-orders {
        text-align: center;
        padding: 4rem 2rem;
        background: white;
        border-radius: 20px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .no-orders svg {
        color: #9ca3af;
        margin-bottom: 1.5rem;
        opacity: 0.5;
    }

    .no-orders h2 {
        font-size: 1.75rem;
        color: #1f2937;
        margin-bottom: 0.5rem;
    }

    .no-orders p {
        color: #6b7280;
        font-size: 1.125rem;
        margin-bottom: 2rem;
    }

    .shop-now-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 1rem 2rem;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
    }

    .shop-now-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(102, 126, 234, 0.4);
    }

    .orders-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(500px, 1fr));
        gap: 1.5rem;
    }

    .order-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        transition: all 0.3s ease;
        border: 2px solid transparent;
    }

    .order-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 24px -4px rgba(0, 0, 0, 0.15);
        border-color: #667eea;
    }

    .order-card-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 1.25rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .order-id {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .order-label {
        color: rgba(255, 255, 255, 0.8);
        font-size: 0.875rem;
        font-weight: 500;
    }

    .order-number {
        color: white;
        font-size: 1.25rem;
        font-weight: 700;
    }

    .order-date {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: rgba(255, 255, 255, 0.9);
        font-size: 0.875rem;
    }

    .order-date svg {
        stroke: currentColor;
    }

    .order-content {
        padding: 1.5rem;
    }

    .order-product {
        display: flex;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .order-product-image {
        width: 100px;
        height: 100px;
        border-radius: 12px;
        background-size: cover;
        background-position: center;
        flex-shrink: 0;
        border: 2px solid #f3f4f6;
    }

    .order-product-info {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .order-product-info h3 {
        font-size: 1.125rem;
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 0.75rem;
    }

    .order-details {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .quantity-badge,
    .price-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.375rem 0.75rem;
        background: #f3f4f6;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 500;
        color: #4b5563;
    }

    .quantity-badge svg {
        stroke: #667eea;
    }

    .order-footer {
        border-top: 2px solid #f3f4f6;
        padding-top: 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .order-total {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .order-total span:first-child {
        font-size: 0.875rem;
        color: #6b7280;
        font-weight: 500;
    }

    .total-amount {
        font-size: 1.75rem;
        font-weight: 700;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .order-actions {
        display: flex;
        gap: 0.75rem;
    }

    .btn-invoice,
    .btn-view {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.25rem;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.875rem;
        transition: all 0.2s ease;
    }

    .btn-invoice {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
    }

    .btn-invoice:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(102, 126, 234, 0.4);
    }

    .btn-view {
        background: white;
        color: #667eea;
        border: 2px solid #667eea;
    }

    .btn-view:hover {
        background: #667eea;
        color: white;
    }

    @media (max-width: 768px) {
        .orders-container {
            padding: 1.5rem 1rem;
        }

        .orders-header h1 {
            font-size: 2rem;
            flex-direction: column;
            gap: 0.5rem;
        }

        .orders-header p {
            font-size: 1rem;
        }

        .orders-grid {
            grid-template-columns: 1fr;
        }

        .order-card-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.75rem;
        }

        .order-product {
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        .order-product-image {
            width: 120px;
            height: 120px;
        }

        .order-footer {
            flex-direction: column;
            align-items: stretch;
        }

        .order-total {
            text-align: center;
            padding-bottom: 1rem;
            border-bottom: 1px solid #f3f4f6;
        }

        .order-actions {
            flex-direction: column;
        }

        .btn-invoice,
        .btn-view {
            justify-content: center;
            width: 100%;
        }
    }

    @media (max-width: 480px) {
        .orders-header h1 {
            font-size: 1.75rem;
        }

        .order-number {
            font-size: 1.125rem;
        }

        .order-date {
            font-size: 0.8rem;
        }

        .order-product-info h3 {
            font-size: 1rem;
        }

        .total-amount {
            font-size: 1.5rem;
        }
    }
</style>
